# =========================================
# Supabase (required)
# =========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================================
# Existing EWG connector settings
# =========================================
EWG_BASE_URL=https://www.ewg.org
EWG_RATE_LIMIT_MS=2000

# =========================================
# Existing API ingest auth
# =========================================
INGEST_API_KEY=your-secret-ingest-key

# =========================================
# Resolver / worker settings
# =========================================
RESOLVER_VERSION=resolver-v1
WORKER_ID=resolver-worker-1
BATCH_SIZE=20
POLL_MS=2000

# =========================================
# Internal auth shared by Node worker <-> Edge Functions
# Must match Supabase function secret
# =========================================
INTERNAL_FUNCTION_BEARER=your-internal-shared-secret

# =========================================
# Edge Function URLs
# Replace your-project with your actual Supabase project ref
# =========================================
LOOKUP_API_URL=https://your-project.functions.supabase.co/lookup-api

# =========================================
# Audit exports
# =========================================
AUDIT_OUTPUT_DIR=out
UNRESOLVED_EXPORT_LIMIT=10000
ENQUEUE_LIMIT=5000
ENQUEUE_BATCH_SIZE=500

# =========================================
# Reverse GTIN Lookup
# =========================================
REVERSE_GTIN_MAX_MATERIALS=500
REVERSE_GTIN_MAX_PAGES=3

# =========================================
# UPC Enrichment (UPCitemdb.com)
# Free tier: 100 req/day
# =========================================
UPCITEMDB_RATE_LIMIT_MS=1500
ENRICH_UPC_BATCH_SIZE=50

# =========================================
# PlastChem XLSX ingestion
# Path to plastchem_db_v1.01.xlsx (defaults to project root)
# =========================================
PLASTCHEM_DB_PATH=plastchem_db_v1.01.xlsx

# =========================================
# Open Food Facts rate limiting
# =========================================
OFF_RATE_LIMIT_MS=600
